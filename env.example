# Recipe-to-Cart — Environment Variables
# Copy this to .env.local and fill in your values

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-api03-...

# Swiggy OAuth credentials (from Builders Club dashboard)
SWIGGY_CLIENT_ID=your_client_id_here
SWIGGY_CLIENT_SECRET=your_client_secret_here

# Swiggy OAuth endpoints
SWIGGY_AUTH_URL=https://auth.swiggy.in/oauth/authorize
SWIGGY_TOKEN_URL=https://auth.swiggy.in/oauth/token

# MCP server base URL
SWIGGY_MCP_BASE_URL=https://mcp.swiggy.in/instamart/v1

# Redirect URI (must match exactly what's registered in Builders Club)
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback

# App URL (for production)
NEXT_PUBLIC_APP_URL=https://recipe-to-cart.app

# Optional: session encryption key (generate with: openssl rand -base64 32)
SESSION_SECRET=your_session_secret_here
