# Session cookie encryption (openssl rand -base64 32)
SESSION_SECRET=replace-with-random-32-byte-base64

# Public app URL (used for OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3002/auth/callback

# Swiggy MCP
SWIGGY_MCP_BASE=https://mcp.swiggy.com
SWIGGY_IM_URL=https://mcp.swiggy.com/im

# --- Recipe LLM (first match wins) ---
# 1) NVIDIA NIM — https://build.nvidia.com (get API key)
# NVIDIA_API_KEY=nvapi-...
# NVIDIA_NIM_MODEL=meta/llama-3.1-8b-instruct
# NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

# 2) Local Ollama — install from https://ollama.com then: ollama pull llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# 3) Groq — https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# 4) Google Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash
