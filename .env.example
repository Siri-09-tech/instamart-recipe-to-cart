# Session cookie encryption (openssl rand -base64 32)
SESSION_SECRET=replace-with-random-32-byte-base64

# Public app URL (used for OAuth redirect)
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3002/auth/callback

# Swiggy MCP
SWIGGY_MCP_BASE=https://mcp.swiggy.com
SWIGGY_IM_URL=https://mcp.swiggy.com/im

# --- Recipe LLM (pick ONE) ---
# 1) Local Ollama (preferred, free) — install from https://ollama.com then:
#    ollama pull llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# 2) Groq free API key — https://console.groq.com/keys
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# 3) Google Gemini free key — https://aistudio.google.com/apikey
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash
